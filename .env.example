# clean-skill environment (copy to .env.local; never commit real values)

# LLM judge (pick one; clean-skill auto-detects which is set)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
CLEAN_SKILL_JUDGE_MODEL=claude-sonnet-4-5

# Threat intel database
CLEAN_SKILL_DB_URL=postgresql+psycopg://cleanskill:cleanskill@localhost:5432/cleanskill

# Crawler queue
CLEAN_SKILL_REDIS_URL=redis://localhost:6379/0

# Sandbox
CLEAN_SKILL_SANDBOX_IMAGE=cleanskill/sandbox:latest
CLEAN_SKILL_SANDBOX_RUNTIME=runsc          # gVisor; set to "runc" if unavailable
CLEAN_SKILL_SANDBOX_TIMEOUT_S=30
CLEAN_SKILL_SANDBOX_MEMORY_MB=512
CLEAN_SKILL_SANDBOX_CPU_QUOTA=0.5

# API
CLEAN_SKILL_API_HOST=0.0.0.0
CLEAN_SKILL_API_PORT=8080
CLEAN_SKILL_API_TOKEN=
